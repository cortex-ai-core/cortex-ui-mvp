import { NextResponse } from "next/server";
import { createClient } from "@supabase/supabase-js";
import PDFParser from "pdf2json";
import mammoth from "mammoth";

export const runtime = "nodejs";

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!
);

export async function POST(req: Request) {
  try {
    const { path, type } = await req.json();

    if (!path || !type) {
      return NextResponse.json(
        { error: "Missing path or file type" },
        { status: 400 }
      );
    }

    // 1️⃣ Download file from Supabase
    const { data, error } = await supabase.storage
      .from(process.env.SUPABASE_STORAGE_BUCKET!)
      .download(path);

    if (error || !data) {
      return NextResponse.json(
        { error: "Unable to download file", details: error?.message },
        { status: 500 }
      );
    }

    const arrayBuffer = await data.arrayBuffer();
    const buffer = Buffer.from(arrayBuffer);

    let text = "";

    // 2️⃣ Parse PDF
    if (type === "pdf") {
      const pdfParser = new PDFParser();

      text = await new Promise((resolve, reject) => {
        pdfParser.on("pdfParser_dataError", (err) => reject(err.parserError));
        pdfParser.on("pdfParser_dataReady", () => {
          resolve(pdfParser.getRawTextContent());
        });

        pdfParser.parseBuffer(buffer);
      });
    }

    // 3️⃣ Parse DOCX
    else if (type === "docx") {
      const parsed = await mammoth.extractRawText({ buffer });
      text = parsed.value;
    }

    // 4️⃣ Parse TXT
    else if (type === "txt") {
      text = buffer.toString("utf8");
    }

    else {
      return NextResponse.json(
        { error: `Unsupported file type ${type}` },
        { status: 400 }
      );
    }

    // 5️⃣ Normalize text
    text = text.replace(/\s+/g, " ").trim();

    return NextResponse.json(
      {
        success: true,
        path,
        text,
        length: text.length,
      },
      { status: 200 }
    );
  } catch (err: any) {
    console.error("Parse error:", err);
    return NextResponse.json(
      { error: "Parse failure", details: err?.message },
      { status: 500 }
    );
  }
}

