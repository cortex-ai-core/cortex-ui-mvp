/* ============================
   PREMIUM ENTERPRISE UI — Option A
   Cortéx Minimal Sovereign Edition
============================ */

/* ============================
   LEFT SIDEBAR
============================ */
.sidebar {
  width: 260px;
  background: #ffffff;
  border-right: 1px solid #e5e5e5;
  padding: 28px 20px;
  display: flex;
  flex-direction: column;
  gap: 22px;
  overflow-y: auto;
}

.sidebarTitle {
  font-size: 26px;
  font-weight: 700;
}

.newChatButton {
  width: 100%;
  padding: 12px 0;
  background: #000;
  color: #fff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  transition: 0.2s ease;
  border: none;
  cursor: pointer;
}

.newChatButton:hover {
  background: #333;
}

/* ============================
   SIDEBAR SECTIONS
============================ */
.section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* ============================
   FILE / EPHEMERAL
============================ */
.ephemeralLabel {
  font-size: 14px;
  font-weight: 600;
}

.ephemeralInput {
  font-size: 13px;
}

.ephemeralList {
  margin-top: 6px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.ephemeralItem {
  font-size: 12px;
  color: #555;
}

/* ============================
   DOCUMENTS LIST
============================ */
.docItem {
  background: #f5f5f5;
  padding: 10px;
  border-radius: 8px;
  font-size: 13px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.deleteButton {
  align-self: flex-start;
  padding: 4px 8px;
  background: #000;
  color: #fff;
  border: none;
  font-size: 12px;
  border-radius: 6px;
  cursor: pointer;
}

.deleteButton:hover {
  background: #333;
}

.emptyDocs {
  font-size: 12px;
  color: #999;
}

/* ============================
   MAIN CHAT AREA
============================ */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #f7f7f8;
}

/* ============================
   CHAT MESSAGES
============================ */
.messagesContainer {
  flex: 1;
  padding: 26px;
  overflow-y: auto;
}

/* ============================
   EMPTY STATE
============================ */
.emptyState {
  text-align: center;
  margin-top: 80px;
  color: #777;
}

.emptyState h2 {
  font-size: 22px;
  margin-bottom: 8px;
}

.emptyState p {
  font-size: 14px;
}

/* ============================
   TYPING INDICATOR
============================ */
.typing {
  font-size: 13px;
  color: #888;
  margin-top: 10px;
  font-style: italic;
}

/* ============================
   INPUT AREA (Premium)
============================ */
.inputBar {
  padding: 20px;
  border-top: 1px solid #e5e5e5;
  background: #fff;
}

.inputWrapper {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
}

/* ============================
   INPUT + BUTTON ROW
============================ */
.inputRow {
  display: flex;
  align-items: flex-end;
  gap: 12px;
}

/* ============================
   TEXT INPUT
============================ */
.input {
  flex: 1;
  height: 48px;
  border: 1px solid #ccc;
  border-radius: 10px;
  padding: 0 14px;
  font-size: 14px;
  outline: none;
}

.input:focus {
  border-color: #000;
}

/* ============================
   SEND BUTTON
============================ */
.sendButton {
  width: 48px;
  height: 48px;
  background: #000;
  color: #fff;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  transition: 0.2s ease;
}

.sendButton:hover {
  background: #333;
}
