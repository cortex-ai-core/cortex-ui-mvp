"use client";

import { useState } from "react";

export default function LoginPage() {
  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");

  async function handleLogin() {
    try {
      const res = await fetch(
        `${process.env.NEXT_PUBLIC_BACKEND_URL}/api/auth/login`,
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ username, password }),
        }
      );

      const data = await res.json();

      if (data.token) {
        localStorage.setItem("token", data.token);
        window.location.href = "/";
      } else {
        alert("Invalid credentials");
      }
    } catch (err) {
      console.error("LOGIN ERROR:", err);
      alert("Login failed");
    }
  }

  return (
    <div className="h-screen flex items-center justify-center bg-[#f7f7f8]">
      <div className="w-full max-w-md bg-white p-8 rounded-2xl shadow-sm border">

        {/* Title */}
        <h1 className="text-2xl font-semibold text-center mb-1">
          Cortéx
        </h1>
        <p className="text-center text-sm text-gray-500 mb-6">
          Private Intelligence System
        </p>

        {/* Inputs */}
        <div className="flex flex-col gap-4">
          <input
            type="text"
            placeholder="Username"
            className="h-11 px-4 border rounded-lg text-sm outline-none focus:border-black"
            value={username}
            onChange={(e) => setUsername(e.target.value)}
          />

          <input
            type="password"
            placeholder="Password"
            className="h-11 px-4 border rounded-lg text-sm outline-none focus:border-black"
            value={password}
            onChange={(e) => setPassword(e.target.value)}
          />

          {/* Button */}
          <button
            onClick={handleLogin}
            className="h-11 bg-black text-white rounded-lg text-sm font-medium hover:bg-[#222] transition"
          >
            Sign In
          </button>
        </div>

      </div>
    </div>
  );
}
